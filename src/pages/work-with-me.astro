---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import tomaszPhoto from "../assets/tomasz-szymanski.jpeg";
import mariuszPhoto from "../assets/mariusz-gadarkowski.jpeg";
import mateuszPhoto from "../assets/mateusz-eichler.jpeg";
---

<BaseLayout
    title="Work With Me — Michał Parkoła"
    description="I help software founders scale delivery and operations from 5 to 50 people."
>
    <div class="page">
        <p class="lede">
            I help software founders with delivery & operations. I run things,
            optimize systems and develop leaders, so that the founder can focus
            on strategy and growth. I cut to the core of problems and take (or
            help you take) the next best action.
        </p>

        <section>
            <h2>Who this is for</h2>
            <ul>
                <li>
                    Ideal fit: software founders running companies with 5-50
                    people
                </li>

                <li>
                    You've had some success but you're experiencing growing
                    pains or uncertainty about the future
                </li>
                <li>
                    You're doing things with AI but it not a core part of your
                    company (yet)
                </li>
            </ul>
        </section>

        <section>
            <h2>How I can help</h2>

            <h3>Full-time or fractional management</h3>
            <p>
                I join your team full-time or 2-3 days/week and solve the most
                painful problems: delays, overload, AI-anxiety, conflict &
                misalignment, lack of progress, etc. Things work and you can
                focus only on the most important topics.
            </p>

            <h3>Coaching and Facilitation</h3>
            <p>
                Focused engagements for specific problems: scaling the team,
                fixing a broken delivery process, integrating AI, or just making
                sure you do what you know you need to do. I support you and your
                team to decide on the best way forward. I diagnose, recommend
                and debug — then get out of the way.
            </p>
        </section>

        <section>
            <h2>My Background</h2>
            <p>
                15+ years in software — from system design through agile
                coaching to senior engineering/delivery management with more
                than one detour into entrepreneurship. I've grown teams, shipped
                products and built the processes that support healthy companies.
            </p>
            <p>
                I write about delivery, teams and leadership on <a href="/blog"
                    >this blog</a
                > and <a
                    href="https://www.youtube.com/playlist?list=PLvzbhlS5zmdVwoIf6HtW3F0t6zEVmsp5N"
                    >give talks on the subject</a
                > since 2011.
            </p>
            <p>
                <a href="https://www.linkedin.com/in/michalparkola/"
                    >Full background on LinkedIn →</a
                >
            </p>
        </section>

        <section class="testimonials">
            <h2>What people say</h2>
            <div class="video-grid">
                <div class="video">
                    <iframe
                        src="https://www.youtube.com/embed/Q66lrF22_cc"
                        title="Testimonial — agile transformation"
                        allowfullscreen
                        loading="lazy"></iframe>
                    <p class="caption">
                        On leading an agile transformation together at a large
                        corporation
                    </p>
                </div>
                <div class="video">
                    <iframe
                        src="https://www.youtube.com/embed/TXmvprnDfSU"
                        title="Testimonial — engineering growth"
                        allowfullscreen
                        loading="lazy"></iframe>
                    <p class="caption">
                        An engineer I managed — grew from mid to staff level in
                        about 2 years
                    </p>
                </div>
            </div>

            <div class="quotes">
                <blockquote>
                    <Image
                        src={mariuszPhoto}
                        alt="Mariusz Gądarkowski"
                        class="quote-photo"
                        width={48}
                        format="webp"
                        quality={85}
                    />
                    <div>
                        <p>
                            "Thanks to his support, we avoided common mistakes
                            and applied new practices with full understanding of
                            the principles and values behind them."
                        </p>
                        <cite>Mariusz Gądarkowski — CTO, Gemius</cite>
                    </div>
                </blockquote>
                <blockquote>
                    <Image
                        src={tomaszPhoto}
                        alt="Tomasz Szymański"
                        class="quote-photo"
                        width={48}
                        format="webp"
                        quality={85}
                    />
                    <div>
                        <p>
                            "Michał proved to be a very valuable product owner
                            with very strict focus on providing business value.
                            He is a perfect fit for a product-oriented company."
                        </p>
                        <cite>Tomasz Szymański — CEO, SoftwareMill</cite>
                    </div>
                </blockquote>
                <blockquote>
                    <Image
                        src={mateuszPhoto}
                        alt="Mateusz Eichler"
                        class="quote-photo"
                        width={48}
                        format="webp"
                        quality={85}
                    />
                    <div>
                        <p>
                            "His intelligence, creativity and drive allowed him
                            to add value at all stages of product development:
                            from business analysis to functional design as well
                            as marketing and sales."
                        </p>
                        <cite
                            >Mateusz Eichler — Director, Altkom Software &
                            Consulting</cite
                        >
                    </div>
                </blockquote>
            </div>
        </section>

        <section class="cta">
            <h2>Let's talk</h2>
            <p>
                <a href="mailto:michal.parkola@gmail.com">Email me</a>
                with a few sentences about your situation and we'll set up a free
                intro call.
            </p>
        </section>
    </div>
</BaseLayout>

<style>
    h1 {
        font-size: 2.5rem;
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }

    .lede {
        margin-bottom: 3rem;
    }

    section {
        margin-bottom: 3rem;
    }

    h2 {
        font-size: 1.5rem;
        color: #2c3e50;
        margin-bottom: 1rem;
    }

    .quotes {
        margin-top: 2rem;
    }

    .quotes blockquote {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        margin: 0 0 1.5rem 0;
    }

    .quote-photo {
        border-radius: 50%;
        flex-shrink: 0;
    }

    .quotes blockquote p {
        margin: 0 0 0.25rem 0;
        font-style: italic;
    }

    .quotes cite {
        font-style: normal;
        font-size: 0.85rem;
        color: #666;
    }

    .video-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .video iframe {
        width: 100%;
        aspect-ratio: 16 / 9;
        border: none;
        border-radius: 8px;
    }

    .video .caption {
        margin-top: 0.5rem;
        font-size: 0.85rem;
        color: #666;
    }

    @media (max-width: 600px) {
        .video-grid {
            grid-template-columns: 1fr;
        }
    }

    ul {
        padding-left: 1.5rem;
    }

    li {
        margin-bottom: 0.25rem;
    }

    a {
        color: #5c8d11;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }

    .cta {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 2rem;
        text-align: center;
    }

    .cta h2 {
        margin-top: 0;
    }

    .cta p {
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 2rem;
        }
    }
</style>
