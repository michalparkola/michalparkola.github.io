---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import photo from "../assets/michal-parkola.jpg";

const pickedSlugs = [
    "i-used-claude-code-as-my-productivity-coach-for-a-week",
    "fast-decision-making-method-for-teams",
    "psychological-safety-5-things",
    "organize-your-communication-around-focused-work",
    "how-to-become-a-great-team",
    "three-pits-of-team-despair",
];

const allPosts = await getCollection("blog");
const pickedPosts = pickedSlugs
    .map((slug) => allPosts.find((p) => p.slug === slug))
    .filter(Boolean);
---

<BaseLayout title="Michał Parkoła">
    <div class="page">
        <section class="intro">
            <Image src={photo} alt="Michał Parkoła" class="photo" width={120} format="webp" quality={85} />
            <p>
                Hi! I'm Michał – a senior manager specializing in delivery and
                operations for software companies.
            </p>
            <p>
                I've spent 15+ years building teams, shipping products, and
                setting up effective process. I helped scale
                <a href="https://appsilon.com/">Appsilon</a> from 25 to 100 people
                in the span of about 2 years. I took care of teams and developed leaders
                at <a href="https://9livesdata.com/">9LivesData</a>. I founded
                several companies (not all survived, sadly).
            </p>
            <p>
                Right now I'm focused on helping software founders navigate the
                transition to AI – solving old problems with new tools and new
                problems with old tools.
            </p>
            <p>
                I do this as a <strong>senior manager</strong> (a part of your team),
                a <strong>fractional</strong> manager, or
                <strong>consultant</strong>. I also <strong>coach</strong> founders
                and <strong>facilitate</strong> group workshops helping you cut to
                the root of the problem and take the next concrete action.
            </p>
            <p class="cta">
                <a href="/work-with-me/">Work with me →</a>
            </p>
        </section>

        <section class="projects">
            <h2>Projects</h2>
            <ul>
                <li>
                    🧶 <a href="https://GrowWithTapestry.com/">Tapestry</a> — AI planning
                    partner for founders and teams
                </li>
                <li>
                    📺 <a href="https://LearnThis.GrowWithTapestry.com"
                        >LearnThis</a
                    > — turn YouTube videos into actionable plans in your context
                </li>
                <li>
                    🧠 A private <strong>mastermind</strong> for CEOs navigating the
                    transition to AI (contact me if you're interested)
                </li>
                <li>
                    ✉️ A <strong>newsletter</strong> for founders in the age of AI
                    (coming soon)
                </li>
            </ul>
        </section>

        <section class="writing">
            <h2>Selected writing</h2>
            <ul>
                {
                    pickedPosts.map((post) => (
                        <li>
                            <a href={`/blog/${post.slug}/`}>
                                {post.data.title}
                            </a>
                        </li>
                    ))
                }
            </ul>
            <p class="more-link">
                <a href="/blog/">All articles →</a>
            </p>
        </section>

        <section class="projects">
            <h2>Other works</h2>
            <ul>
                <li>
                    🌐 <a href="https://fluidcircle.net"> FluidCircle.net</a> an in-depth
                    guide to Scrum and other Agile topics (in Polish).
                </li>
                <li>
                    📺 <a
                        href="https://www.youtube.com/playlist?list=PLvzbhlS5zmdVwoIf6HtW3F0t6zEVmsp5N"
                        >Talks and Interviews</a
                    > on YouTube.
                </li>
                <li>
                    📚 <a href="https://michalparkola.gumroad.com/">Books</a> about
                    <a
                        href="https://michalparkola.gumroad.com/l/jak-zmienic-swiat?layout=profile"
                        >change management</a
                    > (translation) and <a
                        href="https://michalparkola.gumroad.com/l/LAO"
                        >communication</a
                    > (chapter).
                </li>
            </ul>
        </section>
    </div>
</BaseLayout>

<style>
    .intro {
        margin: 2rem 0 3rem;
    }

    .photo {
        border-radius: 50%;
        float: right;
        margin: 0 0 1rem 1.5rem;
    }

    .intro p {
        margin-bottom: 1rem;
    }

    .intro a {
        color: #5c8d11;
        text-decoration: none;
    }

    .intro a:hover {
        text-decoration: underline;
    }

    .intro .cta {
        margin-top: 1.5rem;
    }

    .intro .cta a {
        font-weight: 600;
        font-size: 1.1rem;
    }

    h2 {
        font-size: 1.5rem;
        color: #2c3e50;
        margin-bottom: 1rem;
    }

    .projects,
    .writing {
        margin-bottom: 3rem;
    }

    .projects ul,
    .writing ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .projects li {
        margin-bottom: 0.75rem;
    }

    .projects li a {
        color: #2c3e50;
        text-decoration: none;
        font-weight: 600;
    }

    .projects li a:hover {
        color: #5c8d11;
    }

    .writing li {
        padding: 0.4rem 0;
    }

    .writing li a {
        color: #2c3e50;
        text-decoration: none;
        font-weight: 500;
    }

    .writing li a:hover {
        color: #5c8d11;
    }

    .writing time {
        color: #999;
        font-size: 0.85rem;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .more-link {
        margin-top: 1rem;
    }

    .more-link a {
        color: #5c8d11;
        text-decoration: none;
        font-weight: 500;
    }

    .more-link a:hover {
        text-decoration: underline;
    }

    @media (max-width: 768px) {
        .intro p {
            font-size: 1.05rem;
        }

        .writing li {
            flex-direction: column;
            gap: 0.25rem;
        }
    }
</style>
