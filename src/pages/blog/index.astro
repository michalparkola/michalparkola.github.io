---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const sortedPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Articles — Michał Parkoła" description="Writing about delivery, teams and leadership in software.">
  <section class="all-posts-section">
    <div class="posts-grid">
      {sortedPosts.map((post) => (
        <article class="post-card">
          {post.data.heroImage && (
            <Image
              src={post.data.heroImage}
              alt={post.data.title}
              class="post-image"
              width={600}
              format="webp"
            />
          )}
          <div class="post-content">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toISOString().split('T')[0]}
            </time>
            <h3>
              <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
            </h3>
            <p class="post-description">{post.data.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .all-posts-section {
    margin: 2rem 0;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: #2c3e50;
    text-align: center;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .post-card {
    border: 1px solid #eee;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    background: white;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .post-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .post-content {
    padding: 1.5rem;
  }

  .post-content time {
    color: #666;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .post-content h3 {
    margin: 0 0 1rem 0;
    font-size: 1.3rem;
    line-height: 1.4;
  }

  .post-content a {
    text-decoration: none;
    color: #2c3e50;
  }

  .post-content a:hover {
    color: #5C8D11;
  }

  .post-description {
    color: #666;
    line-height: 1.6;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .post-card {
      margin: 0 -1rem;
      border-left: none;
      border-right: none;
      border-radius: 0;
    }
  }
</style>
