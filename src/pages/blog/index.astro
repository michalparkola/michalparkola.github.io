---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');

const categories: Record<string, string[]> = {
  "AI": [
    "i-used-claude-code-as-my-productivity-coach-for-a-week",
  ],
  "Teams": [
    "psychological-safety-5-things",
    "how-to-become-a-great-team",
    "three-pits-of-team-despair",
    "fast-decision-making-method-for-teams",
    "when-making-decisions-as-a-team-aim-for-soft-consensus",
    "what-does-google-know-about-teams",
    "pawel-brodzinski-on-collective-intelligence",
    "ratio-of-positivity",
    "acts-of-leadership-at-all-levels",
    "play-well-with-your-team-by-asking-who-has-the-ball-for-each-important-topic-over-time",
    "one-of-us",
    "assume-positive-intent",
    "how-might-this-make-sense-2",
  ],
  "Delivery": [
    "next",
    "outcome-and-action",
    "how-to-stay-sane-on-the-road-to-meaningful-outcomes",
    "make-outcomes-visible",
    "very-big-decisions",
    "juicy-goals-find-out-what-people-actually-care-about",
    "how-to-start-with-why",
    "how-to-learn-from-experience",
    "dont-rely-on-wow-effects",
  ],
  "Communication": [
    "make-it-easy-for-people-to-understand-you",
    "communicate-well-in-short-chunks-of-writing",
    "make-your-communication-concise",
    "make-your-communication-concrete",
    "meaningful",
    "de-noise-your-email",
    "show-dont-tell",
    "how-to-speak-so-that-others-listen",
  ],
  "Remote": [
    "organize-your-communication-around-focused-work",
    "high-perf-team-virtual-space",
    "consistent-ia-across-tools",
    "direct-attention-and-store-information",
    "enable-knowledge-to-grow-over-time-with-asyncabc",
    "dont-keep-valuable-ideas-locked-up",
    "use-trello",
  ],
  "Leadership & Growth": [
    "train-like-an-athlete",
    "what-does-it-mean-to-be-a-great-scrum-master",
    "how-to-get-good-feedback",
    "first-find-the-good",
    "check-your-story",
    "make-good-decisions-in-difficult-situations",
    "you-cant-solve-problems-while-angry-or-fearful",
    "limits-regeneration-meaning",
    "build-learning-into-everything-you-do",
    "know-what-you-want",
    "get-inspired-by-stories",
    "a-note-on-empathy-and-compassion",
    "what-can-you-learn-from-the-part-of-yourself-you-hate-the-most",
    "three-false-beliefs",
    "7-things-i-learned-that-helped-me-build-a-successful-career-without-a-university-degree",
    "a-new-operating-system-for-learning",
    "the-old-what-vs-how-debate",
    "asking-the-user",
    "7-pitfalls-that-can-destroy-new-product-owners-my-talk-at-agile-by-example-2014",
    "thinking-tools-for-product-owners-my-talk-at-agile-by-example-2014",
  ],
};

const grouped = Object.entries(categories).map(([name, slugs]) => ({
  name,
  posts: slugs
    .map((slug) => allPosts.find((p) => p.slug === slug))
    .filter(Boolean),
}));
---

<BaseLayout title="Writing — Michał Parkoła" description="Writing about delivery, teams and leadership in software.">
  {grouped.map((group) => (
    <section class="category">
      <h2>{group.name}</h2>
      <ul class="posts">
        {group.posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>

<style>
  .category {
    margin-bottom: 2.5rem;
  }

  h2 {
    font-size: 1.5rem;
    color: #2c3e50;
    margin-bottom: 0.75rem;
  }

  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .posts li {
    padding: 0.4rem 0;
  }

  .posts li a {
    color: #2c3e50;
    text-decoration: none;
    font-weight: 500;
  }

  .posts li a:hover {
    color: #5c8d11;
  }
</style>
