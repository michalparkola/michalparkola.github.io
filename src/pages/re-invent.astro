        color: #5c8d11;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }

    .hero p {
        margin-bottom: 1rem;
    }

    .edition-note {
        background: #f4f9ec;
        border-left: 4px solid #5c8d11;
        padding: 0.75rem 1rem;
        border-radius: 0 8px 8px 0;
    }

    .cta-inline a {
        font-weight: 600;
        font-size: 1.1rem;
    }

    section {
        margin-bottom: 3rem;
    }

    h2 {
        font-size: 1.5rem;
        color: #2c3e50;
        margin-bottom: 1rem;
    }

    h3 {
        font-size: 1.15rem;
        color: #2c3e50;
        margin: 1.5rem 0 0.5rem;
    }

    .obstacles li {
        margin-bottom: 1rem;
    }

    .fit {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .fit h2 {
        font-size: 1.15rem;
    }

    .fit ul {
        padding-left: 1.25rem;
    }

    .fit li {
        margin-bottom: 0.5rem;
    }

    .price {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 2rem;
        text-align: center;
    }

    .price h2 {
        margin-top: 0;
    }

    .price-amount {
        font-size: 2rem;
